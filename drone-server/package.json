{
  "name": "drone-server",
  "version": "1.0.0",
  "description": "Helios drone companion computer server — controls LED spotlight via GPIO",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:mock": "cross-env MOCK_GPIO=true ts-node src/server.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "onoff": "^6.0.3",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
